{
  "name": "pi-blackbytes",
  "version": "2.3.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "files": [
    "prompts/*.md",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && bun run build:js && bun run build:types",
    "build:js": "bun build src/index.ts --outfile dist/index.js --target node --packages external",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "bench:startup": "node --import tsx scripts/measure-startup.ts",
    "bench:tool-result": "node --import tsx scripts/measure-tool-result.ts",
    "check:size": "bash scripts/check-size.sh",
    "check": "bun run lint && bun run typecheck && bun run build && bun run test && bun run check:size"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "yaml": "^2.8.3",
    "zod": "^4"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "typebox": "*"
  },
  "overrides": {
    "typebox": "^1.1.24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuongntr/pi-blackbytes.git"
  },
  "homepage": "https://github.com/cuongntr/pi-blackbytes#readme",
  "bugs": {
    "url": "https://github.com/cuongntr/pi-blackbytes/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@mariozechner/pi-tui": "^0.69.0",
    "tsx": "^4.21.0",
    "typebox": "^1.1.24",
    "typescript": "^5.5"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
