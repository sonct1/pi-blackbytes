{
  "name": "pi-blackbytes",
  "version": "0.2.2",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && bun run build:js && bun run build:types",
    "build:js": "bun build src/index.ts --outfile dist/index.js --target node --packages external",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "bash -c 'node --import tsx --test src/**/*.test.ts'",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "bench:startup": "node --import tsx scripts/measure-startup.ts",
    "bench:tool-result": "node --import tsx scripts/measure-tool-result.ts",
    "check:size": "bash scripts/check-size.sh"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.33",
    "fast-glob": "^3.3.3",
    "yaml": "^2.8.3",
    "zod": "^4"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuongntr/pi-blackbytes.git"
  },
  "homepage": "https://github.com/cuongntr/pi-blackbytes#readme",
  "bugs": {
    "url": "https://github.com/cuongntr/pi-blackbytes/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "tsx": "^4.21.0",
    "typescript": "^5.5"
  }
}
